# Supabase configuration
# Get these from your Supabase project: https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Set to "true" to enable server sync (SSE/polling fallback when Supabase is not configured)
VITE_ENABLE_SERVER_SYNC=true
